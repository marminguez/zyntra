# PostgreSQL
DATABASE_URL="postgresql://zyntra:zyntra@localhost:5432/zyntra?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Field-level encryption – 32-byte key encoded as base64
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ZYNTRA_FIELD_ENCRYPTION_KEY="CHANGE_ME_BASE64_32_BYTES"

# Rate limiting (requests per minute)
RATE_LIMIT_INGEST=60
RATE_LIMIT_RISK=60
